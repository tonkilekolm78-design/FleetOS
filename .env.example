# ============================================================
#  FleetOS — Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit .env to Git
# ============================================================

# ── DATABASE (Render PostgreSQL) ─────────────────────────────
DATABASE_URL=postgresql://fleetos_user:yourpassword@dpg-xxxxx.oregon-postgres.render.com/fleetos
DB_SSL=true
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── API SERVER ───────────────────────────────────────────────
PORT=3000
NODE_ENV=production
API_BASE_URL=https://api.fleetos.co.za

# ── SECURITY ─────────────────────────────────────────────────
JWT_SECRET=replace-with-long-random-string-min-64-chars
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12

# ── GPS TCP LISTENER ─────────────────────────────────────────
GPS_TCP_PORT=8080
GPS_TCP_HOST=0.0.0.0
# Teltonika sends pings every N seconds — configure on device
GPS_PING_INTERVAL_SEC=30
# Alert if no ping received for this many minutes
GPS_SIGNAL_LOSS_THRESHOLD_MIN=10

# ── GEOFENCE ENGINE ──────────────────────────────────────────
# How often the geofence engine processes the queue (ms)
GEOFENCE_PROCESS_INTERVAL_MS=5000
# Default radius if zone has none set
GEOFENCE_DEFAULT_RADIUS_M=200

# ── CROSS-CHECK ENGINE ───────────────────────────────────────
# Run cross-check analysis every N minutes
CROSSCHECK_INTERVAL_MIN=5
# CPK variance % that triggers a flag
CPK_ALERT_THRESHOLD_PCT=15
# ETA breach threshold in minutes before flagging
ETA_BREACH_THRESHOLD_MIN=15
# Dwell time alert — minutes vehicle in zone beyond expected
DWELL_ALERT_THRESHOLD_MIN=60

# ── CORS ─────────────────────────────────────────────────────
# Your Cloudflare frontend URL
ALLOWED_ORIGINS=https://fleetos.co.za,https://www.fleetos.co.za,http://localhost:5500

# ── LOGGING ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/fleetos.log

# ── PDF STORAGE ──────────────────────────────────────────────
# Local path for generated pay stubs (use Render disk or S3)
PDF_OUTPUT_PATH=./storage/paystubs
