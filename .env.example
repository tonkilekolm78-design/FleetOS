# Copy this to .env and fill in your values
DATABASE_URL=postgresql://user:password@host:5432/fleetos
DB_SSL=true
JWT_SECRET=replace-with-a-long-random-string-minimum-32-characters
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12
PORT=3000
NODE_ENV=development
GPS_TCP_PORT=8080
CROSSCHECK_INTERVAL_MIN=5
CPK_ALERT_THRESHOLD_PCT=15
ETA_BREACH_THRESHOLD_MIN=15
DWELL_ALERT_THRESHOLD_MIN=60
EMPLOYEE_BASE_SALARY=18500
ALLOWED_ORIGINS=*
